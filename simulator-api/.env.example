FIREBASE_PROJECT_ID=aa-lids-simulator
# One of the credential options below is required for the API:
# FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/serviceAccount.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@aa-lids-simulator.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
PORT=8787

# SNAPP Ops (same value as SNAPP_INTEGRATION_API_KEY on snapp-ops)
SNAPP_BASE_URL=https://snapp-ops.vercel.app
SNAPP_API_KEY=change-me-to-a-long-random-secret
# SNAPP_PUBLIC_URL=https://snapp-ops.vercel.app

# Only needed for one-time migration from Supabase:
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
